<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Onum | Data pipelines</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #09090e;
            --bg-secondary: #111118;
            --bg-tertiary: #18181f;
            --bg-elevated: #1e1e28;
            --border-subtle: rgba(255,255,255,0.06);
            --border-medium: rgba(255,255,255,0.1);
            --text-primary: #f8fafc;
            --text-secondary: #a1a1aa;
            --text-muted: #71717a;
            --purple: #a78bfa;
            --purple-glow: rgba(167, 139, 250, 0.4);
            --blue: #60a5fa;
            --cyan: #22d3ee;
            --pink: #f472b6;
            --orange: #fb923c;
            --green: #4ade80;
            --red: #f87171;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            overflow-x: hidden;
        }

        /* === SIDEBAR === */
        .sidebar {
            width: 250px; min-height: 100vh;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border-subtle);
            padding: 20px 14px;
            display: flex; flex-direction: column;
            position: fixed; left: 0; top: 0; bottom: 0;
            z-index: 100;
        }

        .sidebar-brand {
            display: flex; align-items: center; gap: 12px;
            padding: 8px 14px; margin-bottom: 28px;
        }
        .brand-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--purple), var(--blue));
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; font-weight: 800; color: white;
            box-shadow: 0 4px 20px var(--purple-glow);
        }
        .brand-name { font-size: 22px; font-weight: 700; letter-spacing: -0.5px; }

        .search-box {
            display: flex; align-items: center; gap: 10px;
            padding: 11px 14px; margin-bottom: 24px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 10px;
            color: var(--text-muted); font-size: 13px;
            cursor: pointer; transition: all 0.2s;
        }
        .search-box:hover { border-color: var(--border-medium); background: var(--bg-elevated); }
        .search-box kbd { 
            margin-left: auto; padding: 3px 8px; 
            background: var(--bg-primary); border: 1px solid var(--border-subtle);
            border-radius: 5px; font-size: 11px; font-family: inherit;
        }

        .nav-group { margin-bottom: 28px; }
        .nav-label { 
            font-size: 10px; font-weight: 600; color: var(--text-muted); 
            padding: 8px 14px; text-transform: uppercase; letter-spacing: 1px;
        }
        
        .nav-item {
            display: flex; align-items: center; gap: 12px;
            padding: 11px 14px; border-radius: 10px;
            color: var(--text-secondary); font-size: 14px; font-weight: 500;
            cursor: pointer; transition: all 0.15s ease;
            position: relative;
        }
        .nav-item:hover { background: var(--bg-tertiary); color: var(--text-primary); }
        .nav-item.active { 
            background: linear-gradient(135deg, rgba(167,139,250,0.15), rgba(96,165,250,0.1)); 
            color: var(--purple);
        }
        .nav-item.active::before {
            content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
            width: 3px; height: 20px; background: var(--purple); border-radius: 0 3px 3px 0;
        }
        .nav-icon { width: 20px; height: 20px; opacity: 0.7; }
        .nav-item:hover .nav-icon, .nav-item.active .nav-icon { opacity: 1; }
        .nav-badge { 
            margin-left: auto; padding: 3px 10px; 
            background: var(--purple); border-radius: 12px;
            font-size: 11px; font-weight: 600; color: white;
        }

        .sidebar-footer {
            margin-top: auto; padding: 16px 14px;
            border-top: 1px solid var(--border-subtle);
        }
        .user-info { display: flex; align-items: center; gap: 12px; }
        .user-avatar {
            width: 36px; height: 36px; border-radius: 10px;
            background: linear-gradient(135deg, var(--cyan), var(--green));
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 600;
        }
        .user-name { font-size: 13px; font-weight: 600; }
        .user-role { font-size: 11px; color: var(--text-muted); }

        /* === MAIN CONTENT === */
        .main { 
            flex: 1; margin-left: 250px; 
            display: flex; flex-direction: column; 
            min-height: 100vh;
        }

        /* Header */
        .topbar {
            display: flex; align-items: center; justify-content: space-between;
            padding: 16px 32px;
            background: rgba(17, 17, 24, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-subtle);
            position: sticky; top: 0; z-index: 50;
        }

        .topbar-left { display: flex; align-items: center; gap: 20px; }
        .page-title { font-size: 20px; font-weight: 700; }
        .date-badge {
            display: flex; align-items: center; gap: 8px;
            padding: 8px 14px; background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle); border-radius: 8px;
            font-size: 13px; color: var(--text-secondary);
        }

        .topbar-right { display: flex; align-items: center; gap: 12px; }
        .btn {
            display: flex; align-items: center; gap: 8px;
            padding: 10px 18px; border-radius: 10px;
            font-size: 13px; font-weight: 500;
            cursor: pointer; transition: all 0.2s;
            border: 1px solid var(--border-subtle);
            background: var(--bg-tertiary); color: var(--text-secondary);
        }
        .btn:hover { background: var(--bg-elevated); color: var(--text-primary); border-color: var(--border-medium); }
        .btn-primary { 
            background: linear-gradient(135deg, var(--purple), var(--blue)); 
            border: none; color: white;
            box-shadow: 0 4px 15px var(--purple-glow);
        }
        .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

        /* Content */
        .content { padding: 28px 32px; flex: 1; }

        /* Stats Section */
        .stats-section { display: flex; gap: 24px; margin-bottom: 32px; }

        .circular-card {
            width: 200px; padding: 24px;
            background: var(--bg-secondary);
            border: 1px solid var(--border-subtle);
            border-radius: 20px;
            display: flex; flex-direction: column; align-items: center;
            position: relative; overflow: hidden;
        }
        .circular-card::before {
            content: ''; position: absolute; top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: conic-gradient(from 180deg, transparent, var(--purple-glow), transparent);
            animation: rotate 8s linear infinite;
            opacity: 0.1;
        }
        @keyframes rotate { to { transform: rotate(360deg); } }

        .circular-progress {
            position: relative; width: 120px; height: 120px; margin-bottom: 16px;
        }
        .circular-progress svg { transform: rotate(-90deg); }
        .circular-progress circle { fill: none; stroke-linecap: round; }
        .circular-bg { stroke: var(--border-subtle); stroke-width: 8; }
        .circular-fill { 
            stroke: url(#circularGrad); stroke-width: 8;
            stroke-dasharray: 339.292; transition: stroke-dashoffset 1s ease;
        }
        .circular-center {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            text-align: center;
        }
        .circular-percent { font-size: 32px; font-weight: 800; }
        .circular-subtitle { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
        .circular-saved { font-size: 14px; font-weight: 600; color: var(--green); margin-top: 8px; }

        .metric-card {
            flex: 1; padding: 24px;
            background: var(--bg-secondary);
            border: 1px solid var(--border-subtle);
            border-radius: 20px;
            transition: all 0.3s;
        }
        .metric-card:hover { border-color: var(--border-medium); transform: translateY(-2px); }
        .metric-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
        .metric-icon {
            width: 44px; height: 44px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px;
        }
        .metric-icon.blue { background: rgba(96, 165, 250, 0.12); }
        .metric-icon.orange { background: rgba(251, 146, 60, 0.12); }
        .metric-icon.pink { background: rgba(244, 114, 182, 0.12); }
        .metric-icon.cyan { background: rgba(34, 211, 238, 0.12); }
        .metric-label { font-size: 13px; color: var(--text-muted); }
        .metric-value { font-size: 28px; font-weight: 700; margin-bottom: 6px; }
        .metric-change { font-size: 12px; display: flex; align-items: center; gap: 4px; }
        .metric-change.down { color: var(--red); }
        .metric-change.up { color: var(--green); }

        /* Sankey Section */
        .sankey-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-subtle);
            border-radius: 20px; padding: 28px;
            margin-bottom: 28px;
            position: relative; overflow: hidden;
        }
        .sankey-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
            background: linear-gradient(90deg, transparent, var(--purple), transparent);
            opacity: 0.5;
        }

        .sankey-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
        .sankey-title { font-size: 16px; font-weight: 600; }
        .sankey-tabs { display: flex; gap: 6px; }
        .tab {
            display: flex; align-items: center; gap: 6px;
            padding: 8px 14px; border-radius: 8px;
            background: transparent; border: 1px solid var(--border-subtle);
            color: var(--text-muted); font-size: 12px; font-weight: 500;
            cursor: pointer; transition: all 0.2s;
        }
        .tab:hover { background: var(--bg-tertiary); color: var(--text-secondary); }
        .tab.active { background: var(--bg-tertiary); border-color: var(--purple); color: var(--purple); }

        .column-headers {
            display: flex; justify-content: space-between;
            padding: 0 40px; margin-bottom: 12px;
        }
        .col-header { 
            display: flex; align-items: center; gap: 8px;
            font-size: 11px; font-weight: 600; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .col-header svg { width: 14px; height: 14px; opacity: 0.6; }

        .sankey-visual { 
            position: relative; height: 420px;
            background: linear-gradient(180deg, rgba(167,139,250,0.02), transparent);
            border-radius: 16px;
        }
        .sankey-svg { width: 100%; height: 100%; }

        /* Animated particles container */
        .particles-container {
            position: absolute; inset: 0; pointer-events: none; overflow: hidden;
        }

        .flow-particle {
            position: absolute; width: 6px; height: 6px;
            background: var(--purple); border-radius: 50%;
            box-shadow: 0 0 10px var(--purple), 0 0 20px var(--purple-glow);
            animation: flowParticle 4s ease-in-out infinite;
        }

        @keyframes flowParticle {
            0% { left: 5%; top: var(--start-y); opacity: 0; transform: scale(0.5); }
            10% { opacity: 1; transform: scale(1); }
            90% { opacity: 1; transform: scale(1); }
            100% { left: 95%; top: var(--end-y); opacity: 0; transform: scale(0.5); }
        }

        /* Logs Section */
        .logs-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-subtle);
            border-radius: 20px; padding: 24px;
        }

        .logs-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .logs-title { font-size: 16px; font-weight: 600; }
        .live-tag {
            display: flex; align-items: center; gap: 8px;
            padding: 6px 14px; border-radius: 20px;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            font-size: 11px; font-weight: 600; color: var(--red);
        }
        .live-pulse { width: 8px; height: 8px; background: var(--red); border-radius: 50%; animation: pulse 1.5s infinite; }
        @keyframes pulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); } 50% { box-shadow: 0 0 0 6px rgba(239,68,68,0); } }

        .logs-table { 
            font-family: 'JetBrains Mono', 'Fira Code', monospace; 
            font-size: 12px;
        }
        .logs-header-row {
            display: grid; grid-template-columns: 100px 60px 100px 1fr;
            gap: 16px; padding: 10px 16px;
            border-bottom: 1px solid var(--border-subtle);
            color: var(--text-muted); font-size: 11px; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .logs-body { max-height: 300px; overflow-y: auto; }
        .logs-body::-webkit-scrollbar { width: 6px; }
        .logs-body::-webkit-scrollbar-track { background: transparent; }
        .logs-body::-webkit-scrollbar-thumb { background: var(--border-medium); border-radius: 3px; }

        .log-row {
            display: grid; grid-template-columns: 100px 60px 100px 1fr;
            gap: 16px; align-items: center;
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-subtle);
            transition: background 0.15s;
            animation: slideIn 0.3s ease;
        }
        .log-row:hover { background: var(--bg-tertiary); }
        @keyframes slideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }

        .log-ts { color: var(--text-muted); }
        .log-lvl { 
            padding: 4px 10px; border-radius: 6px; 
            font-size: 10px; font-weight: 600; text-transform: uppercase;
            text-align: center;
        }
        .log-lvl.error { background: rgba(248,113,113,0.15); color: var(--red); }
        .log-lvl.warn { background: rgba(251,146,60,0.15); color: var(--orange); }
        .log-lvl.info { background: rgba(96,165,250,0.15); color: var(--blue); }
        .log-lvl.debug { background: rgba(113,113,122,0.15); color: var(--text-muted); }
        .log-ns { color: var(--purple); }
        .log-msg { color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* Footer */
        .footer {
            padding: 20px 32px;
            border-top: 1px solid var(--border-subtle);
            text-align: center;
            color: var(--text-muted); font-size: 12px;
        }

        /* SVG Definitions */
        .svg-defs { position: absolute; width: 0; height: 0; }
    </style>
</head>
<body>
    <svg class="svg-defs">
        <defs>
            <linearGradient id="circularGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#a78bfa"/>
                <stop offset="50%" stop-color="#60a5fa"/>
                <stop offset="100%" stop-color="#22d3ee"/>
            </linearGradient>
            <linearGradient id="flowGrad1" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#60a5fa" stop-opacity="0.6"/>
                <stop offset="100%" stop-color="#a78bfa" stop-opacity="0.6"/>
            </linearGradient>
            <linearGradient id="flowGrad2" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#a78bfa" stop-opacity="0.5"/>
                <stop offset="100%" stop-color="#f472b6" stop-opacity="0.5"/>
            </linearGradient>
            <linearGradient id="flowGrad3" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#22d3ee" stop-opacity="0.4"/>
                <stop offset="100%" stop-color="#4ade80" stop-opacity="0.4"/>
            </linearGradient>
            <filter id="glow">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
        </defs>
    </svg>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">O</div>
            <span class="brand-name">Onum</span>
        </div>

        <div class="search-box">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Search
            <kbd>⌘K</kbd>
        </div>

        <nav class="nav-group">
            <div class="nav-label">Main</div>
            <div class="nav-item active">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
                Home
            </div>
            <div class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="3"/></svg>
                Listeners
            </div>
            <div class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                Pipelines
            </div>
            <div class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                Data sinks
            </div>
            <div class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                Actions
                <span class="nav-badge">9</span>
            </div>
        </nav>

        <nav class="nav-group">
            <div class="nav-label">Monitor</div>
            <div class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Alerts
            </div>
            <div class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                Enrichment
            </div>
        </nav>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">DA</div>
                <div>
                    <div class="user-name">Data Admin</div>
                    <div class="user-role">Administrator</div>
                </div>
            </div>
        </div>
    </aside>

    <main class="main">
        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Home</h1>
                <div class="date-badge">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Range is 12 hours ago
                </div>
            </div>
            <div class="topbar-right">
                <button class="btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    Search
                </button>
                <button class="btn" style="color: var(--cyan); border-color: var(--cyan);">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/><path d="M21 3v5h-5"/></svg>
                    Charlotte AI
                </button>
                <button class="btn btn-primary" onclick="fetchData()">Create new</button>
            </div>
        </header>

        <div class="content">
            <section class="stats-section">
                <div class="circular-card">
                    <div class="circular-progress">
                        <svg width="120" height="120" viewBox="0 0 120 120">
                            <circle class="circular-bg" cx="60" cy="60" r="54"/>
                            <circle class="circular-fill" cx="60" cy="60" r="54" id="progress-ring"/>
                        </svg>
                        <div class="circular-center">
                            <div class="circular-percent" id="net-saved">75%</div>
                            <div class="circular-subtitle">Net saved</div>
                        </div>
                    </div>
                    <div class="circular-saved" id="saved-gb">-383.49GB</div>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <div class="metric-icon blue">📡</div>
                        <div class="metric-label">Listeners</div>
                    </div>
                    <div class="metric-value" id="listeners">80K</div>
                    <div class="metric-change down">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l5-5 5 5"/><path d="M7 7l5 5 5-5"/></svg>
                        <span>0.93% EPS</span>
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <div class="metric-icon orange">🎯</div>
                        <div class="metric-label">Data sinks</div>
                    </div>
                    <div class="metric-value" id="data-sinks">2.5K</div>
                    <div class="metric-change down">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l5-5 5 5"/><path d="M7 7l5 5 5-5"/></svg>
                        <span>0.71% EPS</span>
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <div class="metric-icon pink">📊</div>
                        <div class="metric-label">Data volume</div>
                    </div>
                    <div class="metric-value" id="data-volume">507.9GB</div>
                    <div class="metric-change down">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l5-5 5 5"/><path d="M7 7l5 5 5-5"/></svg>
                        <span>1.3%</span>
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <div class="metric-icon cyan">⚡</div>
                        <div class="metric-label">Estimation (24h)</div>
                    </div>
                    <div class="metric-value" id="estimation">1.02TB</div>
                    <div class="metric-change down">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l5-5 5 5"/><path d="M7 7l5 5 5-5"/></svg>
                        <span>IN 1.3% → OUT 248.83GB</span>
                    </div>
                </div>
            </section>

            <section class="sankey-card">
                <div class="sankey-top">
                    <h2 class="sankey-title">Data Flow Visualization</h2>
                    <div class="sankey-tabs">
                        <div class="tab active">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                            Listeners
                        </div>
                        <div class="tab">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>
                            Clusters
                        </div>
                        <div class="tab">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/></svg>
                            Labels
                        </div>
                        <div class="tab">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                            Pipelines
                        </div>
                        <div class="tab">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                            Data sinks
                        </div>
                    </div>
                </div>

                <div class="column-headers">
                    <div class="col-header"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> Listeners</div>
                    <div class="col-header"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg> Clusters</div>
                    <div class="col-header"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/></svg> Labels</div>
                    <div class="col-header"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg> Pipelines</div>
                    <div class="col-header"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg> Data sinks</div>
                </div>

                <div class="sankey-visual">
                    <svg class="sankey-svg" id="sankey-svg"></svg>
                    <div class="particles-container" id="particles"></div>
                </div>
            </section>

            <section class="logs-card">
                <div class="logs-top">
                    <h2 class="logs-title">Live Event Stream</h2>
                    <div class="live-tag"><div class="live-pulse"></div>LIVE</div>
                </div>
                <div class="logs-table">
                    <div class="logs-header-row">
                        <div>Timestamp</div>
                        <div>Level</div>
                        <div>Namespace</div>
                        <div>Message</div>
                    </div>
                    <div class="logs-body" id="logs-body">
                        <div class="log-row" style="color: var(--text-muted); justify-content: center; display: flex;">
                            Connecting to pipeline...
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <footer class="footer">
            K8s Log Pipeline Dashboard • Powered by ClickHouse • <span id="update-time">--:--:--</span>
        </footer>
    </main>

    <script>
        const $ = id => document.getElementById(id);
        const fmt = n => n >= 1e9 ? (n/1e9).toFixed(2)+'TB' : n >= 1e6 ? (n/1e6).toFixed(1)+'M' : n >= 1e3 ? (n/1e3).toFixed(1)+'K' : n.toString();
        const time = ts => ts ? new Date(ts).toLocaleTimeString('en-US', {hour12:false}) : '--:--:--';
        const esc = t => { const d=document.createElement('div'); d.textContent=t; return d.innerHTML; };

        const colors = ['#60a5fa', '#a78bfa', '#f472b6', '#fb923c', '#22d3ee', '#4ade80'];

        function drawSankey(nsCounts) {
            const svg = $('sankey-svg');
            const rect = svg.parentElement.getBoundingClientRect();
            const w = rect.width || 1000;
            const h = 420;
            
            const total = Object.values(nsCounts).reduce((a,b) => a+b, 0) || 1;
            const entries = Object.entries(nsCounts).sort((a,b) => b[1] - a[1]);
            
            const cols = { 
                listeners: 70, 
                clusters: w * 0.22, 
                labels: w * 0.42, 
                pipelines: w * 0.62, 
                sinks: w - 80 
            };
            
            let svgContent = '';
            let particlesHtml = '';
            let y = 30;
            
            entries.forEach(([ns, count], i) => {
                const height = Math.max(35, (count / total) * 320);
                const color = colors[i % colors.length];
                const midY = y + height / 2;
                
                // Listener node
                svgContent += `<g class="sankey-node-group" style="cursor:pointer">
                    <rect x="15" y="${y}" width="110" height="${height}" rx="6" fill="${color}" opacity="0.85"/>
                    <text x="70" y="${midY - 6}" text-anchor="middle" fill="white" font-size="12" font-weight="600">${ns}</text>
                    <text x="70" y="${midY + 10}" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="11">${(count/1000).toFixed(1)}K events</text>
                </g>`;
                
                // Flow to clusters
                const clusterY = 80 + i * 55;
                svgContent += `<path d="M125,${midY} C${w*0.15},${midY} ${w*0.18},${clusterY} ${cols.clusters},${clusterY}" 
                    fill="none" stroke="url(#flowGrad1)" stroke-width="${height*0.5}" stroke-linecap="round" opacity="0.5">
                    <animate attributeName="stroke-dasharray" values="0,500;500,0" dur="${3+i*0.3}s" repeatCount="indefinite"/>
                </path>`;
                
                // Cluster node
                svgContent += `<g>
                    <rect x="${cols.clusters - 25}" y="${clusterY - 18}" width="50" height="36" rx="6" fill="${color}" opacity="0.6"/>
                    <text x="${cols.clusters}" y="${clusterY + 4}" text-anchor="middle" fill="white" font-size="9" font-weight="500">cluster</text>
                </g>`;
                
                // Flow to labels
                const labelY = 60 + i * 50;
                svgContent += `<path d="M${cols.clusters + 25},${clusterY} C${w*0.32},${clusterY} ${w*0.36},${labelY} ${cols.labels},${labelY}" 
                    fill="none" stroke="url(#flowGrad2)" stroke-width="${height*0.4}" stroke-linecap="round" opacity="0.5"/>`;
                
                // Label node
                svgContent += `<g>
                    <rect x="${cols.labels - 35}" y="${labelY - 20}" width="70" height="40" rx="6" fill="${color}" opacity="0.5"/>
                    <text x="${cols.labels}" y="${labelY + 2}" text-anchor="middle" fill="white" font-size="9" font-weight="500">${ns.substring(0,10)}</text>
                    <text x="${cols.labels}" y="${labelY + 14}" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-size="8">${(count/1000).toFixed(1)}K</text>
                </g>`;
                
                // Flow to pipelines
                const pipelineY = 100 + i * 45;
                svgContent += `<path d="M${cols.labels + 35},${labelY} C${w*0.52},${labelY} ${w*0.55},${pipelineY} ${cols.pipelines},${pipelineY}" 
                    fill="none" stroke="url(#flowGrad1)" stroke-width="${height*0.35}" stroke-linecap="round" opacity="0.55"/>`;
                
                // Pipeline node
                svgContent += `<g>
                    <rect x="${cols.pipelines - 35}" y="${pipelineY - 18}" width="70" height="36" rx="6" fill="${color}" opacity="0.65"/>
                    <text x="${cols.pipelines}" y="${pipelineY + 4}" text-anchor="middle" fill="white" font-size="9" font-weight="500">parser</text>
                </g>`;
                
                // Flow to sink
                const sinkY = 80 + i * 45;
                svgContent += `<path d="M${cols.pipelines + 35},${pipelineY} C${w*0.72},${pipelineY} ${w*0.78},${sinkY} ${cols.sinks - 40},${sinkY}" 
                    fill="none" stroke="url(#flowGrad3)" stroke-width="${height*0.3}" stroke-linecap="round" opacity="0.6"/>`;
                
                // Particles
                for (let p = 0; p < 2; p++) {
                    particlesHtml += `<div class="flow-particle" style="--start-y: ${midY}px; --end-y: ${sinkY}px; animation-delay: ${i*0.5 + p*2}s; animation-duration: ${4 + p}s;"></div>`;
                }
                
                y += height + 15;
            });
            
            // ClickHouse sink
            svgContent += `<g>
                <rect x="${cols.sinks - 50}" y="80" width="100" height="${Math.min(y - 80, 300)}" rx="8" fill="url(#flowGrad3)" opacity="0.8"/>
                <text x="${cols.sinks}" y="${Math.min(80 + (y-80)/2, 200)}" text-anchor="middle" fill="white" font-size="14" font-weight="700">ClickHouse</text>
                <text x="${cols.sinks}" y="${Math.min(80 + (y-80)/2 + 20, 220)}" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="12">${fmt(total)}</text>
                <text x="${cols.sinks}" y="${Math.min(80 + (y-80)/2 + 38, 240)}" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-size="10">total events</text>
            </g>`;
            
            svg.innerHTML = svgContent;
            $('particles').innerHTML = particlesHtml;
            
            // Update progress ring
            const progress = Math.min((total / 50000) * 100, 100);
            const circumference = 2 * Math.PI * 54;
            $('progress-ring').style.strokeDashoffset = circumference - (progress / 100) * circumference;
            $('net-saved').textContent = Math.round(progress) + '%';
            $('saved-gb').textContent = '-' + (total / 1000).toFixed(1) + 'GB';
            $('listeners').textContent = Math.round(total / 1000) + 'K';
            $('data-volume').textContent = (total / 1000).toFixed(1) + 'GB';
            $('estimation').textContent = fmt(total * 2);
        }

        function renderLogs(logs) {
            const body = $('logs-body');
            if (!logs || !logs.length) {
                body.innerHTML = '<div class="log-row" style="color:var(--text-muted);justify-content:center;display:flex">No events</div>';
                return;
            }
            body.innerHTML = logs.slice(0, 20).map(log => {
                const lvl = log.level || 'info';
                return `<div class="log-row">
                    <span class="log-ts">${time(log.timestamp)}</span>
                    <span class="log-lvl ${lvl}">${lvl}</span>
                    <span class="log-ns">${esc(log.namespace)}</span>
                    <span class="log-msg">${esc(log.message)}</span>
                </div>`;
            }).join('');
        }

        function fetchData() {
            const xhr = new XMLHttpRequest();
            xhr.open('GET', '/api/logs');
            xhr.onload = function() {
                if (xhr.status === 200) {
                    try {
                        const data = JSON.parse(xhr.responseText);
                        if (data.success && data.data) {
                            const logs = data.data.logs || [];
                            const nsCounts = {};
                            logs.forEach(log => nsCounts[log.namespace] = (nsCounts[log.namespace] || 0) + 1);
                            $('update-time').textContent = new Date().toLocaleTimeString('en-US', {hour12:false});
                            drawSankey(nsCounts);
                            renderLogs(logs);
                        }
                    } catch (e) { console.error(e); }
                }
            };
            xhr.send();
        }

        fetchData();
        setInterval(fetchData, 3000);
        window.addEventListener('resize', fetchData);
    </script>
</body>
</html>
